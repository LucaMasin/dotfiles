{
  "$schema": "https://opencode.ai/config.json",

  "default_agent": "heavy-plan",

  "agent": {
    "heavy-plan": {
      "description": "Use for complex or ambiguous tasks requiring planning, delegation, architectural decisions, or final review.",
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "variant": "xhigh",
      "prompt": "Own task decomposition and architectural decisions. Delegate bounded repository exploration and well-specified implementation work to the appropriate subagent. Review each result before synthesizing the final response. Do not edit files directly; when essential information is missing or an action requires approval, ask rather than guess.",
      "permission": {
        "edit": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "cheap-explorer": "allow",
          "cheap-worker": "allow",
          "balanced-explorer": "allow",
          "balanced-worker": "allow",
          "smart-reviewer": "allow"
        }
      }
    },

    "review": {
      "description": "Use for independent, read-only review of completed changes for correctness, regressions, security, and missing tests.",
      "mode": "primary",
      "model": "openai/gpt-5.6-terra",
      "variant": "xhigh",
      "steps": 24,
      "prompt": "Do not modify files. Prioritize actionable defects by severity with file and line evidence. Review correctness, regressions, security, and missing tests; explicitly say when no findings are identified, and distinguish verified issues from risks.",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "task": "deny"
      }
    },

    "cheap-explorer": {
      "description": "Free worker for defined, simple read-only repository investigation, code search, and concise evidence-based reports. Do not use for difficult or ambiguous analysis.",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "steps": 12,
      "prompt": "Investigate only. Do not modify files, execute shell commands, or delegate. Base conclusions on inspected evidence; cite relevant paths and symbols, report concise findings, and distinguish facts from uncertainty.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny"
      }
    },

    "cheap-worker": {
      "description": "Free worker for defined, simple, well-specified, low-risk implementation tasks with clear acceptance criteria. Use the balanced worker for difficult, ambiguous, or multi-step work.",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "steps": 24,
      "prompt": "Implement only the delegated, defined simple request. Inspect local conventions, make minimal focused edits, and run relevant focused checks if permitted. Stop and report a blocker if the work is ambiguous, difficult, or needs multi-step reasoning; it belongs with the balanced worker. Report changed files, verification, and blockers. Do not delegate or expand scope.",
      "permission": {
        "task": "deny"
      }
    },

    "balanced-explorer": {
      "description": "Use for read-only investigation that needs stronger reasoning than the free explorer. Uses MiniMax M3 with thinking disabled; do not use for implementation work.",
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "variant": "none",
      "steps": 24,
      "prompt": "Investigate only. Do not modify files, execute shell commands, or delegate. Analyze the requested repository question carefully, base conclusions on inspected evidence, cite relevant paths and symbols, and distinguish facts from uncertainty. Report concise findings and recommended next steps when useful.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": "deny"
      }
    },

    "balanced-worker": {
      "description": "Use for difficult, ambiguous, or multi-step implementation tasks that need stronger reasoning than the free worker. Uses MiniMax M3 with thinking enabled; do not use for defined simple work.",
      "mode": "subagent",
      "model": "opencode-go/minimax-m3",
      "variant": "thinking",
      "steps": 36,
      "prompt": "Implement the delegated difficult, ambiguous, or multi-step request. Inspect relevant conventions and dependencies before editing, make focused changes that solve the complete delegated task, and run relevant checks if permitted. Report changed files, verification, decisions, and blockers. Do not delegate or expand scope beyond the request.",
      "permission": {
        "task": "deny"
      }
    },

    "smart-reviewer": {
      "description": "Use for independent, read-only review of completed changes for correctness, regressions, security, and missing tests.",
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "variant": "xhigh",
      "steps": 24,
      "prompt": "Do not modify files. Prioritize actionable defects by severity with file and line evidence. Review correctness, regressions, security, and missing tests; explicitly say when no findings are identified, and distinguish verified issues from risks.",
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "task": "deny"
      }
    }
  }
}
