{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.6-luna",
  "agent": {
    "build": {
      "model": "openai/gpt-5.6-luna",
      "reasoningEffort": "high"
    },
    "plan": {
      "model": "openai/gpt-5.6-sol",
      "reasoningEffort": "high"
    },
    "explore": {
      "model": "opencode/deepseek-v4-flash-free",
      "reasoningEffort": "max"
    },
    "scout": {
      "model": "opencode/deepseek-v4-flash-free",
      "reasoningEffort": "max"
    }
  }
}
