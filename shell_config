# Custom shell configuration --------------------------------------------

# Shortcuts for common commands
alias ls='ls --color'
alias c="clear"
alias lsa="ls -lah"
alias ll='ls -l'
alias h='history'
alias ts='~/scripts/tmux-sessionizer.sh'

# Conda shortcuts
alias ca="conda activate"
alias cl="conda list"
alias cel="conda env list"

# Ping count
alias ping='ping -c 5'
alias pingg='ping -c 5 google.com'

# Find in local directory
alias fld="ls -lah | grep"

# Disk usage
alias dus='du -h --max-depth=1 | sort -hr'

# Own scripts
alias tsesh='python3 ~/scripts/tsesh.py'

# Expose programs
# Check if $HOME/.local/bin/ is not already in the PATH
if [[ ":$PATH:" != *":$HOME/.local/bin/:"* ]]; then
    export PATH="$PATH:$HOME/.local/bin/"
fi

if [[ -n ${ZSH_VERSION:-} ]]; then
    if command -v uv &> /dev/null; then
        eval "$(uv generate-shell-completion zsh)"
    fi

    if command -v uvx &> /dev/null; then
        eval "$(uvx --generate-shell-completion zsh)"
    fi
fi

# Check if nvim is available
if command -v nvim &> /dev/null
then
    # If nvim is available, alias it to vim
    alias vim='nvim'
    alias vi='nvim'
fi

# Setup zoxide
if command -v zoxide &> /dev/null
then
    # Keep zoxide initialization idempotent when this file is sourced again.
    if alias cd &> /dev/null; then
        unalias cd
    fi

    # Check if zi is an alias before trying to unalias it
    if alias zi &> /dev/null; then
        unalias zi
    fi

    # Setup zoxide for the currently running shell, not a stale inherited $SHELL.
    if [[ -n ${ZSH_VERSION:-} ]]; then
        eval "$(zoxide init zsh)"
    elif [[ -n ${BASH_VERSION:-} ]]; then
        eval "$(zoxide init bash)"
    fi

    # Alias z to zoxide
    alias cd="z"
fi

